# === Required ===
TAVILY_API_KEY=
OPENAI_API_KEY=

# === Core LLM ===
OPENAI_MODEL=gpt-4o-mini

# === Pre-call pipeline (optional) ===
COURTLISTENER_TOKEN=
MAX_CASES_PER_ENTITY=8
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic
LEGAL_BATCH_SIZE=10
# Tavily Deep Research (pre-call only — slow multi-step jobs)
# TAVILY_RESEARCH_MODEL=mini
# TAVILY_RESEARCH_CONCURRENCY=6
# TAVILY_RESEARCH_POLL_INTERVAL=4.0
# TAVILY_RESEARCH_MAX_POLLS=60
# TAVILY_RESEARCH_OUTPUT_LENGTH=standard

# === Shared usage limiter (API runs without user keys) ===
USAGE_CURRENT=0
USAGE_MAX=25

# === On-Fly live coaching (optional overrides) ===
# Fast models for hot-path tips and async transcript compaction.
# ONFLY_TIP_MODEL=gpt-4o-mini
# ONFLY_COMPACTION_MODEL=gpt-4o-mini
# Conversation memory: compact when unsummarized chunks or tokens exceed thresholds.
# ONFLY_COMPACT_CHUNK_THRESHOLD=10
# ONFLY_COMPACT_TOKEN_THRESHOLD=3000
# ONFLY_SUMMARY_MAX_TOKENS=3000
# ONFLY_RAW_TAIL_CHUNKS=3
# Reactive mid-call research (quick = 1 Tavily search; deep = several searches synthesized).
# ONFLY_REACTIVE_SEARCH_MAX=3
# ONFLY_DEEP_RESEARCH_MAX=2
# ONFLY_DEEP_MAX_QUERIES=3
# Semantic dedup: suppress repeating the same tip_type within N recent tips.
# ONFLY_TIP_TYPE_WINDOW=3
# Session logging — one JSON dump per session on end (default: on).
# ONFLY_SESSION_LOG=1
# ONFLY_LOG_DIR=   # default: salesbuff/onfly_log/
