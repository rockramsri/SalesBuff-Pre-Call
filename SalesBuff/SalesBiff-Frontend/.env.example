# ── Brand theme (build-time) ───────────────────────────────────────────────
# Selects the visual theme. Baked into the bundle by Vite (import.meta.env).
# One GitHub repo → multiple Vercel projects, each with a different VITE_THEME:
#   VITE_THEME=sunrise   → yellow flat skeuomorphic stage (SalesBuff default)
#   VITE_THEME=prism     → orange→violet gradient, frosted glass
#   VITE_THEME=horizon   → navy→white gradient, dark glass
#   VITE_THEME=folio     → white editorial, royal purple accent
#   VITE_THEME=ember     → warm cream, brown recording theater
# On Vercel: set VITE_THEME in Project → Settings → Environment Variables.
# Locally: copy this file to .env.local and set it, OR run a themed script
# (npm run dev:prism / dev:horizon / dev:folio / dev:ember).
# Unset / unknown values fall back to "sunrise".
VITE_THEME=sunrise

# URL of the deployed SalesBuff Python backend (Render). Used server-side only
# by the TanStack server functions — the browser never calls the backend directly.
# Locally this defaults to http://127.0.0.1:8000 if unset.
SALESBUFF_API_URL=https://your-backend.onrender.com

# The bundled @lovable.dev/vite-tanstack-config defaults Nitro's build target to
# Cloudflare. On Vercel, set this so the build outputs Vercel functions instead.
# (Set it as a Vercel Environment Variable, not just here.)
NITRO_PRESET=vercel
